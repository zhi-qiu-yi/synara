{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "SYNARA_HOME",
    "SYNARA_DESKTOP_WS_URL",
    "SYNARA_BROWSER_USE_PIPE_PATH",
    "SYNARA_BROWSER_PERF",
    "SYNARA_PROVIDER_RUNTIME_IDLE_STOP_MS",
    "SYNARA_GROK_ACP_DEBUG",
    "SYNARA_WEB_SOURCEMAP",
    "SYNARA_SERVER_SOURCEMAP",
    "SYNARA_DESKTOP_SOURCEMAP",
    "DPCODE_MODE",
    "DPCODE_PORT",
    "DPCODE_NO_BROWSER",
    "DPCODE_HOME",
    "DPCODE_AUTH_TOKEN",
    "DPCODE_DESKTOP_WS_URL",
    "T3CODE_LOG_WS_EVENTS",
    "T3CODE_MODE",
    "T3CODE_PORT",
    "T3CODE_NO_BROWSER",
    "T3CODE_HOME",
    "T3CODE_AUTH_TOKEN",
    "T3CODE_DESKTOP_WS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
