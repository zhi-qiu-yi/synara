{
  "name": "@synara/cli",
  "version": "0.5.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emanuele-web04/Synara.git",
    "directory": "apps/server"
  },
  "bin": {
    "synara": "dist/index.mjs",
    "synara-restore-migration-backup": "dist/restoreMigrationBackup.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "node scripts/cli.ts build",
    "start": "node dist/index.mjs",
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --maxWorkers=1 --no-file-parallelism"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@anthropic-ai/claude-agent-sdk": "0.3.207",
    "@anthropic-ai/sdk": "^0.100.0",
    "@earendil-works/pi-agent-core": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@opencode-ai/sdk": "^1.15.13",
    "@pierre/diffs": "^1.2.12",
    "@xterm/headless": "^6.0.0",
    "effect": "catalog:",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "tree-kill": "^1.2.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@synara/contracts": "workspace:*",
    "@synara/shared": "workspace:*",
    "@synara/web": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "4.3.6"
  },
  "engines": {
    "node": "^22.19 || ^23.11 || >=24.10"
  }
